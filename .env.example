# =====================================================
# Uplatnica QR — environment variables
# =====================================================
# Copy this file to .env.local and fill in the values.
# Validation happens at startup via @t3-oss/env-nextjs (src/env.ts).
# Build will fail with a clear error if any required var is missing or wrong type.

# === DATABASE (required) ===

# Postgres connection string. Lokalno preko Docker / OrbStack:
#   docker run -d --name uplatnica-pg -p 5432:5432 \
#     -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=uplatnica_qr postgres:17
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/uplatnica_qr?schema=public"

# === BETTER AUTH (required) ===

# Random 32+ char base64. Generiši: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Public URL deployment-a (mora biti ista kao NEXT_PUBLIC_APP_URL)
BETTER_AUTH_URL="http://localhost:3000"

# === PUBLIC APP URL (required) ===

# Public URL — koristi se za canonical, OG, sitemap, robots.txt
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =====================================================
# Sve ispod je OPCIONO. Aplikacija radi i bez ovih.
# =====================================================

# === SEARCH ENGINE VERIFICATION ===

# Google Search Console verification meta tag (samo kod, npr. "abc123def456")
# https://search.google.com/search-console
GOOGLE_SITE_VERIFICATION=""

# Yandex Webmaster verification
YANDEX_VERIFICATION=""

# === ANALYTICS (izaberi jedno) ===

# Plausible Analytics — privacy-friendly, no cookies, GDPR-friendly
# Ako koristiš plausible.io: vrednost je tvoj domen (npr. "uplatnica-qr.com")
# Ako self-host-uješ: postavi i NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=""

# Google Analytics 4 — alternativa Plausible-u
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# === INDEXNOW (Bing/Yandex auto-ping) ===

# Random hex 16+ char. Generiši: openssl rand -hex 16
# VAŽNO: posle postavljanja, kreiraj fajl public/<INDEXNOW_KEY>.txt
# sa istim string-om unutra (Bing zahteva za verifikaciju vlasništva).
INDEXNOW_KEY=""

# === DEV ONLY ===

# Set to "true" da preskočiš env validaciju (npr. u CI bez svih varijabli)
# SKIP_ENV_VALIDATION="true"
